<UserControl x:Class="NotesApp.Views.NoteCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NotesApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="220" d:DesignWidth="220">

    <Border Background="#1E1E1E" 
            CornerRadius="5" 
            BorderBrush="#333333" 
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок нотатки -->
            <DockPanel Grid.Row="0" Margin="10,10,10,5">
                <TextBlock Text="{Binding Title}" 
                           Foreground="White" 
                           FontWeight="Bold" 
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <!-- Контент нотатки -->
            <Border Grid.Row="1" Padding="10,0">
                <TextBlock Text="{Binding Content}" 
                           Foreground="#AAAAAA" 
                           TextWrapping="Wrap" 
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Дата модифікації та кнопки дій -->
            <DockPanel Grid.Row="2" Margin="10">
                <TextBlock Text="{Binding ModifiedAt, StringFormat=dd.MM.yyyy}" 
                           Foreground="#777777" 
                           VerticalAlignment="Center" 
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            DockPanel.Dock="Right">

                    <Button Content="⭐" 
                            Style="{StaticResource ActionButtonStyle}" 
                            Command="{Binding DataContext.ToggleStarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}" 
                            Foreground="{Binding IsStarred, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFC107|#777777'}"/>

                    <Button Content="📌" 
                            Style="{StaticResource ActionButtonStyle}" 
                            Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}" 
                            Foreground="{Binding IsPinned, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2196F3|#777777'}"/>

                    <Button Content="✏️" 
                            Style="{StaticResource ActionButtonStyle}" 
                            Command="{Binding DataContext.EditNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}"/>

                    <Button Content="🗑️" 
                            Style="{StaticResource ActionButtonStyle}" 
                            Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}" 
                            Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapsed}"/>

                    <Button Content="↩️" 
                            Style="{StaticResource ActionButtonStyle}" 
                            Command="{Binding DataContext.RestoreNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}" 
                            Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>