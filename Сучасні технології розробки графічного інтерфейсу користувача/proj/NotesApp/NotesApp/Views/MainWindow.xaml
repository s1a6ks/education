<Window x:Class="NotesApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NotesApp.Views"
        xmlns:vm="clr-namespace:NotesApp.ViewModels"
        mc:Ignorable="d"
        Title="Notes App" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Window.Resources>
        <!-- Стилі для темної теми -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoteCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <Grid>
                                <TextBlock Text="Пошук..." 
                                           Foreground="#666666"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Бічне меню -->
        <Border Background="#191919" Grid.Column="0">
            <DockPanel>
                <TextBlock Text="Notes App" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="15" 
                           DockPanel.Dock="Top"/>

                <StackPanel DockPanel.Dock="Top" Margin="5">
                    <Button Content="Notes" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding ChangeViewCommand}" 
                            CommandParameter="Notes"/>

                    <Button Content="Starred" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding ChangeViewCommand}" 
                            CommandParameter="Starred"/>

                    <Button Content="Tags" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding ChangeViewCommand}" 
                            CommandParameter="Tags"/>

                    <Button Content="Trash" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding ChangeViewCommand}" 
                            CommandParameter="Trash"/>

                    <Button Content="Settings" 
                            Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding ChangeViewCommand}" 
                            CommandParameter="Settings"/>

                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource SearchBoxStyle}" 
                             Margin="0,15,0,0"/>
                </StackPanel>

                <Button Content="+ New Note" 
                        Foreground="White" 
                        Background="#2E7D32" 
                        BorderThickness="0" 
                        Height="40" 
                        Margin="10" 
                        Command="{Binding AddNoteCommand}" 
                        DockPanel.Dock="Bottom">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1B5E20"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- Основний контент -->
        <Border Grid.Column="1" Background="#121212" Padding="10">
            <DockPanel>
                <!-- Заголовок поточного представлення -->
                <TextBlock Text="{Binding CurrentView}" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="10" 
                           DockPanel.Dock="Top"/>

                <!-- Сітка нотаток -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredNotes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource NoteCardStyle}" Width="220" Height="220">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Заголовок нотатки -->
                                        <DockPanel Grid.Row="0" Margin="10,10,10,5">
                                            <TextBlock Text="{Binding Title}" 
                                                       Foreground="White" 
                                                       FontWeight="Bold" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>

                                        <!-- Контент нотатки -->
                                        <Border Grid.Row="1" Padding="10,0">
                                            <TextBlock Text="{Binding Content}" 
                                                       Foreground="#AAAAAA" 
                                                       TextWrapping="Wrap" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>

                                        <!-- Дата модифікації та кнопки дій -->
                                        <DockPanel Grid.Row="2" Margin="10">
                                            <TextBlock Text="{Binding ModifiedAt, StringFormat=dd.MM.yyyy}" 
                                                       Foreground="#777777" 
                                                       VerticalAlignment="Center" 
                                                       DockPanel.Dock="Left"/>

                                            <StackPanel Orientation="Horizontal" 
                                                        HorizontalAlignment="Right" 
                                                        DockPanel.Dock="Right">

                                                <Button Content="⭐" 
                                                        Style="{StaticResource ActionButtonStyle}" 
                                                        Command="{Binding DataContext.ToggleStarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Foreground="{Binding IsStarred, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFC107|#777777'}"/>

                                                <Button Content="📌" 
                                                        Style="{StaticResource ActionButtonStyle}" 
                                                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Foreground="{Binding IsPinned, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2196F3|#777777'}"/>

                                                <Button Content="✏️" 
                                                        Style="{StaticResource ActionButtonStyle}" 
                                                        Command="{Binding DataContext.EditNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}"/>

                                                <Button Content="🗑️" 
                                                        Style="{StaticResource ActionButtonStyle}" 
                                                        Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapsed}"/>

                                                <Button Content="↩️" 
                                                        Style="{StaticResource ActionButtonStyle}" 
                                                        Command="{Binding DataContext.RestoreNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                        CommandParameter="{Binding}" 
                                                        Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>